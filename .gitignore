# ─────────────────────────────────────────────────────────────
# ROOT
# ─────────────────────────────────────────────────────────────

# ── Environment Variables ─────────────────────────────────────
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.local
**/.env.production

# ── OS / System Files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
# node_modules is huge (thousands of files). Never commit this.
Backend/node_modules/

# ── Logs ──────────────────────────────────────────────────────
Backend/logs/
Backend/*.log
Backend/npm-debug.log*
Backend/yarn-debug.log*
Backend/yarn-error.log*

# ── Puppeteer Cache ───────────────────────────────────────────
# Puppeteer downloads a Chromium binary here. Do not commit it.
Backend/.local-chromium/
Backend/.cache/

# ── Temp / Scratch Test Files ─────────────────────────────────
# These are one-off test scripts we create for debugging
Backend/test_*.js
Backend/scratch/

# ─────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────

# ── Coverage Reports ──────────────────────────────────────────
coverage/

# ── Package Manager Lock Files (optional) ─────────────────────
# Uncomment the line below ONLY if you want to exclude lock files.
# Most teams commit lock files to ensure reproducible installs.
# package-lock.json
# yarn.lock
